{
  "name": "findmybook-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": "22.17.0"
  },
  "packageManager": "npm@10.9.2",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:css": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint:ox": "oxlint -c config/oxlintrc.json src/",
    "lint:fix": "oxlint -c config/oxlintrc.json --fix src/",
    "lint:boundaries": "ast-grep scan -c sgconfig.yml",
    "validate": "npm run check && npm run lint:ox && npm run lint:boundaries && npm run test"
  },
  "dependencies": {
    "@lucide/svelte": "^0.563.1",
    "@stomp/stompjs": "^7.2.0",
    "dompurify": "^3.4.3",
    "sockjs-client": "^1.6.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@ast-grep/cli": "^0.42.2",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/svelte": "^5.2.7",
    "@tsconfig/svelte": "^5.0.6",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^22.17.0",
    "@types/sockjs-client": "^1.5.4",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^10.4.0",
    "eslint-plugin-zod": "^4.4.0",
    "happy-dom": "^20.9.0",
    "oxlint": "^1.65.0",
    "svelte": "^5.55.7",
    "svelte-check": "^4.4.8",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  }
}
